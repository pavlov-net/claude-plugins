#!/usr/bin/env bash
set -euo pipefail

INPUT=$(cat)

# Extract file paths based on tool type.
# Edit/Write: tool_input.file_path
# MultiEdit: tool_input.edits[].file_path (deduplicated)
TOOL_NAME=$(echo "$INPUT" | jq -r '.tool_name // empty')

case "$TOOL_NAME" in
  MultiEdit)
    FILES=$(echo "$INPUT" | jq -r '[.tool_input.edits[].file_path] | unique | .[]' 2>/dev/null)
    ;;
  *)
    FILES=$(echo "$INPUT" | jq -r '.tool_input.file_path // empty' 2>/dev/null)
    ;;
esac

[ -z "$FILES" ] && exit 0

format_file() {
  local file="$1"
  [ -f "$file" ] || return 0

  case "$file" in
    *.go)
      if command -v goimports &>/dev/null; then
        goimports -w "$file"
      elif command -v gofmt &>/dev/null; then
        gofmt -w "$file"
      fi
      ;;
    *.py)
      if command -v ruff &>/dev/null; then
        ruff format --quiet "$file"
      elif command -v black &>/dev/null; then
        black --quiet "$file"
      fi
      ;;
    *.rs)
      if command -v rustfmt &>/dev/null; then
        local edition=""
        local dir
        dir=$(cd "$(dirname "$file")" && pwd)
        while [ "$dir" != "/" ] && [ -n "$dir" ]; do
          if [ -f "$dir/Cargo.toml" ]; then
            edition=$(grep -E '^\s*edition\s*=' "$dir/Cargo.toml" | head -n1 | sed -E 's/.*"([0-9]+)".*/\1/')
            break
          fi
          dir=$(dirname "$dir")
        done
        if [ -n "$edition" ]; then
          rustfmt --edition "$edition" "$file" 2>/dev/null
        else
          rustfmt "$file" 2>/dev/null
        fi
      fi
      ;;
    *.ts|*.tsx|*.js|*.jsx|*.mjs)
      if command -v biome &>/dev/null; then
        biome format --write "$file" 2>/dev/null
      elif [ -x ./node_modules/.bin/biome ] && command -v node &>/dev/null; then
        ./node_modules/.bin/biome format --write "$file" 2>/dev/null
      elif command -v bun &>/dev/null && [ -d ./node_modules/@biomejs ]; then
        bun x biome format --write "$file" 2>/dev/null
      elif command -v npx &>/dev/null && [ -d ./node_modules/@biomejs ]; then
        npx biome format --write "$file" 2>/dev/null
      elif command -v prettier &>/dev/null; then
        prettier --write --log-level silent "$file" 2>/dev/null
      elif [ -x ./node_modules/.bin/prettier ] && command -v node &>/dev/null; then
        ./node_modules/.bin/prettier --write --log-level silent "$file" 2>/dev/null
      elif command -v bun &>/dev/null && [ -d ./node_modules/prettier ]; then
        bun x prettier --write --log-level silent "$file" 2>/dev/null
      fi
      ;;
  esac
}

while IFS= read -r file; do
  format_file "$file" || true
done <<< "$FILES"

exit 0
